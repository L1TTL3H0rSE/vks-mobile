{
  "expo": {
    "name": "Kosygin VCS",
    "slug": "vcs-mobile",
    "version": "1.0.0",
    "scheme": "vksapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "ru.rguk.vks.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "ru.rguk.vks.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-app-auth",
        {
          "android": {
            "appAuthRedirectScheme": "vksmobile"
          },
          "ios": {
            "urlScheme": "vksmobile"
          }
        }
      ],
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Приложению нужен доступ к камере для видеоконференций.",
          "microphonePermission": "Приложению нужен доступ к микрофону для аудиосвязи."
        }
      ],
      "expo-secure-store",
      "expo-router"
    ]
  }
}
